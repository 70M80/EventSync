ENV=development
#DB
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/event_sync
ASYNC_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/event_sync
ENGINE_POOL_SIZE=5
ENGINE_MAX_OVERFLOW=5
COMMAND_TIMEOUT=45
STATEMENT_TIMEOUT="60000"
POOL_RECYCLE=1800
POOL_TIMEOUT=30

LOG_LEVEL=INFO

MAX_USERS_PER_EVENT = 20
MAX_RESPONSES_PER_USER = 10
MAX_TRIES_CODE_GENERATION = 10

# WEBSOCKETS
PING_INTERVAL=30
IDLE_TIMEOUT=120
MAX_CONNECTIONS_PER_EVENT=20

# CORS
CORS_ORIGINS=["http://localhost:8000", "http://127.0.0.1:5173"]

# COOKIE
COOKIE_EXPIRE = 2592000 # 30 days