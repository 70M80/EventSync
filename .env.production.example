ENV=production
# ===== Database =====
DATABASE_URL=postgresql://admin:changeme@db:5432/event_sync
ASYNC_DATABASE_URL=postgresql+asyncpg://admin:changeme@db:5432/event_sync
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=event_sync

ENGINE_POOL_SIZE=5
ENGINE_MAX_OVERFLOW=5
COMMAND_TIMEOUT=45
STATEMENT_TIMEOUT="60000"
POOL_RECYCLE=1800
POOL_TIMEOUT=30

# ===== Security =====
ALGORITHM=HS256

# ===== App =====
LOG_LEVEL=info

# ===== Limits =====
MAX_USERS_PER_EVENT=20
MAX_RESPONSES_PER_USER=10
MAX_TRIES_CODE_GENERATION=10

# ===== WebSockets =====
PING_INTERVAL=30
IDLE_TIMEOUT=120
MAX_CONNECTIONS_PER_EVENT=20

# ===== CORS =====
CORS_ORIGINS=["https://yourdomain.com"]

# ===== SSL =====
DOMAIN=yourdomain.com
CERTBOT_EMAIL=your@email.com

HTTP_PORT=80
HTTPS_PORT=443